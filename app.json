{
  "expo": {
    "name": "CareTrip",
    "slug": "CareTrip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/CareTrip-non.png",
    "splash": {
      "image": "./assets/images/CareTrip-background.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "scheme": "travelapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/CareTrip-non.png",
        "backgroundImage": "./assets/images/CareTrip-non.png",
        "monochromeImage": "./assets/images/CareTrip-non.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CareTrip to access your gallery so you can choose a profile photo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/CareTrip-background.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

{
  "expo": {
    "name": "CareTrip",
    "slug": "CareTrip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/CareTrip-non.png",
    "splash": {
      "image": "./assets/images/CareTrip-background.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "scheme": "travelapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow CareTrip to convert your speech into text for the AI Planner.",
        "NSMicrophoneUsageDescription": "Allow CareTrip to use your microphone for voice input in the AI Planner."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/CareTrip-non.png",
        "backgroundImage": "./assets/images/CareTrip-non.png",
        "monochromeImage": "./assets/images/CareTrip-non.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.CareTrip"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CareTrip to access your gallery so you can choose a profile photo."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/CareTrip-background.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/CareTrip-non.png",
          "color": "#E6F4FE"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow CareTrip to use your microphone for voice input in the AI Planner.",
          "speechRecognitionPermission": "Allow CareTrip to convert your speech into text for the AI Planner.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.as",
            "com.google.android.tts",
            "com.samsung.android.bixby.agent"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e901caaf-55b5-4458-b450-db0f3a438ddc"
      }
    }
  }
}

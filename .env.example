
# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=""
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=""
EXPO_PUBLIC_FIREBASE_PROJECT_ID=""
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=""
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
EXPO_PUBLIC_FIREBASE_APP_ID=""

# AI
EXPO_PUBLIC_GEMINI_API_KEY=""
EXPO_PUBLIC_OPENROUTER_API_KEY=""

# Payments
EXPO_PUBLIC_TEST_PAYMENTS_MODE="functions"

# Firebase Functions — "production" uses deployed functions, "emulator" uses local
EXPO_PUBLIC_FIREBASE_FUNCTIONS_MODE="production"
# Only set in .env.local for local emulator testing (your machine's LAN IP):
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR_HOST=""

# EAS / Push Notifications
EXPO_PUBLIC_EAS_PROJECT_ID=""

# ── Travel API Keys (used in Cloud Functions — add to functions/.env) ──
# Amadeus Self-Service (flights, hotels) — https://developers.amadeus.com
# AMADEUS_API_KEY=""
# AMADEUS_API_SECRET=""
# Kiwi.com Tequila (flights, buses, trains) — https://tequila.kiwi.com
# KIWI_API_KEY=""
# OpenTripMap (attractions, POIs) — https://opentripmap.io
# OPENTRIPMAP_API_KEY=""
# OpenWeatherMap (forecasts) — https://openweathermap.org/api
# OPENWEATHER_API_KEY=""
